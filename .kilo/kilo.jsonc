{
  "$schema": "https://app.kilo.ai/config.json",
  "provider": {
    "iaka-reflexion": {
      "name": "iaka-reflexion",
      "options": {
        "apiKey": "{env:IAKA_API_KEY}",
        "baseURL": "https://iaka-api.apps.ocp4.on-prem.innershift.ssghosting.net/qwen-3.6-35b/v1"
      },
      "models": {
        "qwen-3.6-35b": {
          "name": "Qwen 3.6"
        }
      }
    },
    "iaka-code": {
      "name": "iaka-code",
      "options": {
        "apiKey": "{env:IAKA_API_KEY}",
        "baseURL": "https://iaka-api.apps.ocp4.on-prem.innershift.ssghosting.net/qwen3-coder-30b/v1"
      },
      "models": {
        "qwen3-coder-30b": {
          "name": "Qwen 3 coder"
        }
      }
    }
  },
  "mcp": {
    "gherkin-mcp": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "mcp/gherkin-sever/server.py"
      ],
      "enabled": true
    },
    "rf-docs-mcp": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "mcp/rf-docs-server/server.py"
      ],
      "enabled": true
    },
    "rf-runner-mcp": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "mcp/rf-runner-server/server.py"
      ],
      "enabled": true
    },
    "robocop-mcp": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "mcp/robocop-server/server.py"
      ],
      "enabled": true
    }
  }
}